---
import { testimonials } from "../../data/testimonials";
---

<section class="bg-stone-100 py-16 px-4">

  <div class="max-w-6xl mx-auto">

    <!-- TITLE -->
    <div class="text-center mb-12">

      <h2 class="text-3xl md:text-4xl font-serif text-stone-900">
        Ils me font confiance
      </h2>

      <p class="text-stone-600 mt-3 max-w-xl mx-auto">
        Des résultats concrets pour des chambres d’hôtes, gîtes et entreprises locales.
      </p>

    </div>

    <!-- GRID -->
    <div class="grid gap-6 md:grid-cols-3">

      {testimonials.map((t) => (
        <article
          class="
            bg-white
            border
            border-stone-200
            rounded-2xl
            p-6
            shadow-sm
            hover:shadow-md
            transition
          "
        >

          <!-- STARS -->
          <div class="text-amber-600 mb-3">
            {"★".repeat(t.rating)}
          </div>

          <!-- MESSAGE -->
          <p class="text-stone-700 leading-relaxed mb-6">
            “{t.message}”
          </p>

          <!-- AUTHOR -->
          <div class="border-t border-stone-200 pt-4">

            <p class="font-semibold text-stone-900">
              {t.name}
            </p>

            <p class="text-sm text-stone-600">
              {t.location}
            </p>

          </div>

        </article>
      ))}

    </div>

  </div>

</section>