---
import { Image } from "astro:assets";

const {
  title,
  description,
  primaryButton,
  secondaryButton,
  image,
  badge,
  proof,
} = Astro.props;
---

<section class="relative w-full overflow-hidden">

  <!-- IMAGE FULL WIDTH -->
  <div class="relative w-full h-[80vh] md:h-[90vh]">

    <Image
      src={image.src}
      alt={image.alt}
      class="w-full h-full object-cover"
      loading="eager"
    />

    <!-- GRADIENT POUR LISIBILITÉ -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- TEXTE EN BAS DE L'IMAGE -->
    <div class="absolute bottom-0 left-0 w-full px-6 md:px-16 pb-10 md:pb-14 text-white">

      {badge && (
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm mb-4">
          {badge}
        </div>
      )}

      <h1 class="text-3xl md:text-5xl font-serif leading-tight mb-4 max-w-3xl">
        {title}
      </h1>

      <p class="text-white/80 text-base md:text-lg max-w-2xl">
        {description}
      </p>

      {proof && (
        <div class="mt-4 text-sm text-white/70 border-l border-white/30 pl-4 max-w-xl">
          {proof}
        </div>
      )}

    </div>

  </div>

  <!-- BOUTONS CENTRÉS SOUS L'IMAGE -->
  <div class="flex flex-col sm:flex-row justify-center gap-4 py-10 bg-white">

    <a
      href={primaryButton.link}
      class="bg-black text-white px-6 py-3 rounded-lg font-medium hover:opacity-90 transition"
    >
      {primaryButton.text}
    </a>

    <a
      href={secondaryButton.link}
      class="border border-stone-300 px-6 py-3 rounded-lg font-medium hover:bg-stone-100 transition"
    >
      {secondaryButton.text}
    </a>

  </div>

</section>