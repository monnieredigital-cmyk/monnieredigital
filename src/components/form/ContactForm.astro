---
import { contactFormData } from "../../data/contactForm";
---

<form
  name="contact"
  method="POST"
  data-netlify="true"
  class="
    bg-white
    border
    border-stone-200
    rounded-2xl
    p-6
    md:p-8
    space-y-6
  "
>

  <input
    type="hidden"
    name="form-name"
    value="contact"
  />

  <div>
    <label class="block mb-2 font-medium">
      {contactFormData.labels.requestType}
    </label>

    <select
      id="requestType"
      name="requestType"
      class="
        w-full
        border
        border-stone-300
        rounded-lg
        p-3
      "
    >
      {contactFormData.requestTypes.map((type: { value: string | number | string[] | null | undefined; label: unknown; }) => (
        <option value={type.value}>
          {type.label}
        </option>
      ))}
    </select>
  </div>

  <div
    class="
      grid
      gap-4
      md:grid-cols-2
    "
  >
    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.name}
      </label>

      <input
        type="text"
        name="name"
        required
        class="w-full border border-stone-300 rounded-lg p-3"
      />
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.email}
      </label>

      <input
        type="email"
        name="email"
        required
        class="w-full border border-stone-300 rounded-lg p-3"
      />
    </div>
  </div>

  <div>
    <label class="block mb-2 font-medium">
      {contactFormData.labels.phone}
    </label>

    <input
      type="tel"
      name="phone"
      class="w-full border border-stone-300 rounded-lg p-3"
    />
  </div>

  <!-- Champs devis -->
  <div
    id="quoteFields"
    class="hidden space-y-6"
  >

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.websiteType}
      </label>

      <select
        name="websiteType"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.websiteTypes.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.pages}
      </label>

      <select
        name="pages"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.pageOptions.map((item: any) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div
      class="
        grid
        gap-4
        md:grid-cols-2
      "
    >

      <label>
        <input type="checkbox" name="existingWebsite" />
        {contactFormData.labels.existingWebsite}
      </label>

      <label>
        <input type="checkbox" name="domain" />
        {contactFormData.labels.domain}
      </label>

      <label>
        <input type="checkbox" name="googleBusiness" />
        {contactFormData.labels.googleBusiness}
      </label>

      <label>
        <input type="checkbox" name="seo" />
        {contactFormData.labels.seo}
      </label>

      <label>
        <input type="checkbox" name="maintenance" />
        {contactFormData.labels.maintenance}
      </label>

    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.budget}
      </label>

      <select
        name="budget"
        class="w-full border border-stone-300 rounded-lg p-3"
      >
        {contactFormData.budgetOptions.map((item: unknown) => (
          <option>{item}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.delay}
      </label>

      <input
        type="text"
        name="delay"
        placeholder="Ex : dans le mois"
        class="w-full border border-stone-300 rounded-lg p-3"
      />
    </div>
    
    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.specifications}
      </label>

      <input
        name="specifications"
        class="w-full border border-stone-300 rounded-lg p-3"
      ></input>
    </div>

    <div>
      <label class="block mb-2 font-medium">
        {contactFormData.labels.descriptions}
      </label>

      <textarea
        name="description"
        rows="6"
        class="w-full border border-stone-300 rounded-lg p-3"
      ></textarea>
    </div>

  </div>

  <!-- Message simple -->
  <div id="messageField">

    <label class="block mb-2 font-medium">
      {contactFormData.labels.message}
    </label>

    <textarea
      name="message"
      rows="6"
      class="w-full border border-stone-300 rounded-lg p-3"
    ></textarea>

  </div>

  <button
    type="submit"
    class="
      w-full
      md:w-auto
      bg-amber-600
      hover:bg-amber-700
      text-white
      px-8
      py-3
      rounded-lg
      transition
    "
  >
    {contactFormData.labels.submit}
  </button>

</form>

<script>
  const requestType = document.getElementById( "requestType" ) as HTMLSelectElement | null;

  const quoteFields =
    document.getElementById("quoteFields");

  const messageField =
    document.getElementById("messageField");

  function updateForm() {
    const isQuote =
      requestType?.value === "quote";

    quoteFields?.classList.toggle(
      "hidden",
      !isQuote
    );

    messageField?.classList.toggle(
      "hidden",
      isQuote
    );
  }

  requestType?.addEventListener(
    "change",
    updateForm
  );

  updateForm();
</script>