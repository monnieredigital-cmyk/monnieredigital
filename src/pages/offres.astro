---
import MainLayout from "../layouts/MainLayout.astro";
import CTA from "../components/ui/CTA.astro";

import {
  offerIntro,
  offers,
  businessSolutions
} from "../data/offers";

import { cta } from "../data/cta";
---

<MainLayout
  title="Offres | Monnière Digital"
  description="Création de sites web, visibilité Google et solutions métiers pour chambres d'hôtes, gîtes et artisans."
>

  <!-- HERO -->
  <header class="px-6 py-16 text-center">

    <h1 class="text-4xl md:text-6xl font-serif mb-4">
      Nos offres
    </h1>

    <p class="max-w-2xl mx-auto text-stone-600 text-lg">
      {offerIntro.description}
    </p>

  </header>

  <!-- OFFRES -->
  <section class="max-w-6xl mx-auto px-6 pb-20">

    <div class="grid gap-8 lg:grid-cols-2">

      {offers.map((offer) => (

        <article class="bg-white rounded-2xl shadow p-8">

          <h2 class="text-2xl font-serif mb-2">
            {offer.icon} {offer.title}
          </h2>

          <p class="text-stone-600 mb-6">
            {offer.target}
          </p>

          <ul class="space-y-3 mb-6">

            {offer.includes.map((item) => (

              <li class="flex gap-3">

                <span class="text-green-600 font-bold">
                  ✓
                </span>

                <span>{item}</span>

              </li>

            ))}

          </ul>

          <p class="text-stone-600 border-t pt-6">
            {offer.footer}
          </p>

        </article>

      ))}

    </div>

  </section>

  <!-- SOLUTIONS MÉTIERS -->
  <section class="max-w-6xl mx-auto px-6 pb-20">

    <div class="text-center mb-12">

      <h2 class="text-3xl md:text-4xl font-serif mb-4">
        Solutions adaptées à votre activité
      </h2>

      <p class="text-stone-600 max-w-2xl mx-auto">
        Certaines professions ont des besoins spécifiques.
        Nous proposons des fonctionnalités adaptées à votre métier.
      </p>

    </div>

    <div class="grid gap-8 lg:grid-cols-2">

      {businessSolutions.map((solution) => (

        <article class="bg-white rounded-2xl shadow p-8">

          <h3 class="text-2xl font-serif mb-3">
            {solution.icon} {solution.title}
          </h3>

          <p class="text-stone-600 mb-6">
            {solution.description}
          </p>

          <ul class="space-y-3">

            {solution.items.map((item) => (

              <li class="flex gap-3">

                <span class="text-amber-600 font-bold">
                  ✓
                </span>

                <span>{item}</span>

              </li>

            ))}

          </ul>

        </article>

      ))}

    </div>

  </section>

  <!-- POURQUOI -->
  <section class="max-w-4xl mx-auto px-6 pb-20">

    <div class="bg-stone-100 rounded-2xl p-8">

      <h2 class="text-2xl font-serif mb-4">
        Pourquoi un accompagnement dans le temps ?
      </h2>

      <p class="text-stone-600 mb-4">
        Un site internet ne doit pas être abandonné après sa mise en ligne.
        Il doit rester sécurisé, performant et visible sur Google.
      </p>

      <p class="text-stone-600">
        Notre objectif n'est pas simplement de créer un site, mais de vous aider
        à développer durablement votre visibilité en ligne.
      </p>

    </div>

  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-20">

    <CTA
      title={cta.title}
      description={cta.description}
      buttonText={cta.buttonText}
      buttonLink={cta.buttonLink}
    />

  </section>

</MainLayout>