---
import MainLayout from "../layouts/MainLayout.astro";
import { services } from "../data/services";
import CTA from "../components/ui/CTA.astro";
import { cta } from "../data/cta";
---

<MainLayout
  title="Services | Création de sites web"
  description="Découvrez nos services de création de sites web, SEO et visibilité locale."
>

  <!-- HERO -->
  <header class="px-6 py-16 text-center">
    <h1 class="text-3xl md:text-5xl font-serif mb-4">
      Des services pensés pour générer des clients
    </h1>

    <p class="text-stone-600 max-w-xl mx-auto text-base md:text-lg">
      Sites web, SEO et visibilité locale pour artisans et entreprises.
    </p>
  </header>

  <!-- SERVICES -->
  <main class="max-w-5xl mx-auto px-6 pb-24 space-y-6">

    {services.map((service) => (
      <section class="bg-white rounded-xl shadow p-6 md:p-10">

        <!-- HEADER -->
        <div class="mb-4">
          <h2 class="text-xl md:text-2xl font-serif">
            {service.icon} {service.title}
          </h2>

          <p class="text-stone-600 mt-2">
            {service.description}
          </p>
        </div>

        <!-- LIST -->
        <ul class="space-y-2 text-stone-700 text-sm md:text-base">
          {service.items.map((item) => (
            <li>✔ {item}</li>
          ))}
        </ul>

      </section>
    ))}

    <CTA
        title={cta.title}
        description={cta.description}
        buttonText={cta.buttonText}
        buttonLink={cta.buttonLink}
    />

  </main>

</MainLayout>